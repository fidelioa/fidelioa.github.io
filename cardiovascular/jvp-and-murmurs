    let currentIdx = 0;
    let selectedIdx = null;
    let isSubmitted = false;
    let score = 0;
    let totalSeconds = 90 * 60;
    let timerInterval = null;

    function startTimer() {
        timerInterval = setInterval(() => {
            if (totalSeconds <= 0) {
                clearInterval(timerInterval);
                finishQuiz();
                return;
            }
            totalSeconds--;
            let mins = Math.floor(totalSeconds / 60);
            let secs = totalSeconds % 60;
            document.getElementById('time-display').innerText = 
                `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        }, 1000);
    }

    function renderQuestion() {
        isSubmitted = false;
        selectedIdx = null;
        
        const q = dataset[currentIdx];
        document.getElementById('progress-text').innerText = `Question ${currentIdx + 1} of ${dataset.length}`;
        document.getElementById('vignette-box').innerText = q.vignette;
        
        const oBox = document.getElementById('options-box');
        oBox.innerHTML = '';
        
        q.options.forEach((opt, idx) => {
            const card = document.createElement('div');
            card.className = 'option-card';
            card.setAttribute('onclick', `selectOption(${idx})`);
            card.id = `opt-${idx}`;
            
            const dot = document.createElement('span');
            dot.className = 'radio-dot';
            
            const text = document.createElement('span');
            text.innerText = opt;
            
            card.appendChild(dot);
            card.appendChild(text);
            oBox.appendChild(card);
        });

        document.getElementById('explanation-box').style.display = 'none';
        const aBtn = document.getElementById('action-btn');
        aBtn.innerText = "Submit Answer";
        aBtn.className = "btn btn-primary";
        aBtn.setAttribute("onclick", "submitCurrentAnswer()");
        aBtn.disabled = true;
    }

    function selectOption(idx) {
        if (isSubmitted) return;
        
        selectedIdx = idx;
        const cards = document.getElementsByClassName('option-card');
        for (let i = 0; i < cards.length; i++) {
            cards[i].classList.remove('selected');
        }
        document.getElementById(`opt-${idx}`).classList.add('selected');
        document.getElementById('action-btn').disabled = false;
    }

    function submitCurrentAnswer() {
        if (isSubmitted || selectedIdx === null) return;
        isSubmitted = true;

        const q = dataset[currentIdx];
        const cards = document.getElementsByClassName('option-card');
        
        // Lock options visually
        for (let i = 0; i < cards.length; i++) {
            cards[i].style.cursor = 'default';
        }

        if (selectedIdx === q.correct) {
            score++;
            document.getElementById(`opt-${selectedIdx}`).classList.add('correct-highlight');
        } else {
            document.getElementById(`opt-${selectedIdx}`).classList.add('wrong-highlight');
            document.getElementById(`opt-${q.correct}`).classList.add('correct-highlight');
        }

        // Setup rationale panels
        document.getElementById('rationale-box').innerHTML = q.rationale;
        const dBox = document.getElementById('distractors-box');
        dBox.innerHTML = '';
        q.distractors.forEach(dist => {
            const p = document.createElement('div');
            p.className = 'distractor-paragraph';
            p.innerHTML = dist;
            dBox.appendChild(p);
        });
        
        document.getElementById('explanation-box').style.display = 'block';

        // Mutate dynamic sequence buttons
        const aBtn = document.getElementById('action-btn');
        if (currentIdx < dataset.length - 1) {
            aBtn.innerText = "Next Question";
            aBtn.className = "btn btn-success";
            aBtn.setAttribute("onclick", "advanceNext()");
        } else {
            aBtn.innerText = "View Final Results";
            aBtn.className = "btn btn-success";
            aBtn.setAttribute("onclick", "finishQuiz()");
        }
    }

    function advanceNext() {
        currentIdx++;
        renderQuestion();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function finishQuiz() {
        clearInterval(timerInterval);
        document.getElementById('game-view').style.display = 'none';
        document.getElementById('summary-view').style.display = 'block';
        document.getElementById('final-score').innerText = `${score} / ${dataset.length}`;
        
        let pct = Math.round((score / dataset.length) * 100);
        document.getElementById('percentage-box').innerText = `${pct}% Correct`;
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Launch quiz on load
    startTimer();
    renderQuestion();
</script>

