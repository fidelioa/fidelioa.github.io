    <script>
        let currentQuestionNum = 1;
        const totalQuestionsCount = 40;
        let selectedOptionListItem = null;
        
        let totalSecondsRemaining = 90 * 60;
        const clockDisplayElement = document.getElementById('clock-display');
        
        const countdownTimerInterval = setInterval(() => {
            if (totalSecondsRemaining <= 0) {
                clearInterval(countdownTimerInterval);
                clockDisplayElement.innerText = "00:00";
                terminateSessionBlock();
                return;
            }
            totalSecondsRemaining--;
            let minsCalculated = Math.floor(totalSecondsRemaining / 60);
            let secsCalculated = totalSecondsRemaining % 60;
            clockDisplayElement.innerText = 
                (minsCalculated < 10 ? '0' : '') + minsCalculated + ":" + 
                (secsCalculated < 10 ? '0' : '') + secsCalculated;
        }, 1000);

        document.querySelectorAll('.choices li').forEach(optionNode => {
            optionNode.addEventListener('click', function() {
                const targetCard = this.closest('.question-card');
                if (targetCard.querySelector('.meta-section').classList.contains('revealed')) {
                    return; 
                }
                
                targetCard.querySelectorAll('.choices li').forEach(sibling => {
                    sibling.classList.remove('selected');
                });
                this.classList.add('selected');
                selectedOptionListItem = this;
            });
        });

        const submitButtonElement = document.getElementById('submit-action-btn');
        const nextButtonElement = document.getElementById('next-action-btn');
        
        submitButtonElement.addEventListener('click', () => {
            const currentActiveCardNode = document.querySelector('.question-card[data-qindex="' + currentQuestionNum + '"]');
            const selectedOptionInCard = currentActiveCardNode.querySelector('.choices li.selected');
            
            if (!selectedOptionInCard) {
                alert('Please select an option before checking validation accuracy parameters.');
                return;
            }
            
            const dynamicMetaRegion = currentActiveCardNode.querySelector('.meta-section');
            dynamicMetaRegion.classList.add('revealed');
            
            submitButtonElement.style.display = 'none';
            nextButtonElement.style.display = 'block';
        });

        nextButtonElement.addEventListener('click', () => {
            const coreCurrentCardNode = document.querySelector('.question-card[data-qindex="' + currentQuestionNum + '"]');
            coreCurrentCardNode.classList.remove('active');
            
            currentQuestionNum++;
            
            if (currentQuestionNum <= totalQuestionsCount) {
                document.getElementById('tracker-display').innerText = "Question " + currentQuestionNum + " of " + totalQuestionsCount;
                
                const nextActiveCardNode = document.querySelector('.question-card[data-qindex="' + currentQuestionNum + '"]');
                nextActiveCardNode.classList.add('active');
                
                nextButtonElement.style.display = 'none';
                submitButtonElement.style.display = 'block';
                selectedOptionListItem = null;
            } else {
                clearInterval(countdownTimerInterval);
                terminateSessionBlock();
            }
        });

        function terminateSessionBlock() {
            document.getElementById('qbank-container').style.display = 'none';
            submitButtonElement.style.display = 'none';
            nextButtonElement.style.display = 'none';
            document.querySelector('.qbank-header').style.display = 'none';
            
            const finalScoreContainerOutputElement = document.getElementById('end-block-results');
            finalScoreContainerOutputElement.style.display = 'block';
            document.getElementById('score-text-output').innerText = "Block completed cleanly inside session guidelines.";
        }
    </script>

